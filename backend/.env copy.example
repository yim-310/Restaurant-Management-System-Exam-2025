# Backend Environment Variables
# Copy to .env and fill in your values

# ── Database ────────────────────────────────────────────────────────────────
# Local development (Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rms_db"

# Production — Neon.tech (serverless PostgreSQL 16/17)
# Get from: https://console.neon.tech → Connection String
# DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Security ─────────────────────────────────────────────────────────────────
# Change this to a random 64-char string in production!
JWT_SECRET=rms-dev-secret-key-change-in-production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Local: http://localhost:5173
# Production: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173
